-  fun utf8_backspace_at(string &s, u0 &pos) -> void
-  {
-    if (s.empty() || pos == 0)
-      return;
-
-    u0 i = pos - 1;
-    
-    // Continuation byte (10xxxxxx) yakaladıkça geri git
-    while (i > 0 && ((s[i] & 0xC0) == 0x80))
-      --i;
-
-    s.erase(i, pos - i);
-    pos = i;
-  }
