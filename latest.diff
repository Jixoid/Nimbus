-    auto This = (widget*)this;
-
-    while (true)
-    {
-      Ret += This->point();
-
-      if (auto C = dynamic_cast<scrolling*>(This->parent()))
-        Ret += C->clientPos();
-
-
-      if (!This->parent())
-        return {0,0};
-
-      ef (This->parent() == Target)
-        return Ret;
-
-      el
-        This = This->parent();
-    }
