-
-  inline vec& operator+=  (const vec &It) { _elems += It._elems; return *this; }
-  inline vec& operator-=  (const vec &It) { _elems -= It._elems; return *this; }
-  inline vec& operator*=  (const vec &It) { _elems *= It._elems; return *this; }
-  inline vec& operator/=  (const vec &It) { _elems /= It._elems; return *this; }
-  inline vec& operator%=  (const vec &It) { _elems %= It._elems; return *this; }
