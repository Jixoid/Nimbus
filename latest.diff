-          i8 L = utf8_char_length(*(m_text.c_str() + m_pos));
-          m_text.erase(m_pos, L);
-        }
-        break;
-
-      default:
-        handled = false;
-        break;
-    }
-
-    if (__Key && handled) {
-      update();
-      return;
-    }
-
-    
-    // Backspace (ASCII 0x08)
-    if (KeyStr[0] == 0x08) {
-      if (m_pos > 0) {
