-    // Yazdırılabilir Karakter Girişi (Kontrol karakteri değilse)
-    else if ((u8)KeyStr[0] >= 32 || (u8)KeyStr[0] > 127) { 
-      // Not: 127'den büyükse muhtemelen çok baytlı UTF-8'in başlangıcıdır.
