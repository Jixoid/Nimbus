-
-
-    i8 i = 1;
-    while (true)
-    {
-      if (i > len) return i;
-
-      if ((*(str -i) & 0xC0) != 0x80) // UTF-8 continuation bytes'i atla
-        break;
-
-      ++i;
-    }
-
-    return i;
-  }
