-      case 111: // Home
-        m_pos = 0;
-        break;
-
-      case 116: // End
-        m_pos = (u32)m_text.size();
-        break;
-
-      case 113: // Left
-        if (m_pos > 0)
-          m_pos -= utf8_char_length_from_end(m_text.c_str() + m_pos, m_pos);
