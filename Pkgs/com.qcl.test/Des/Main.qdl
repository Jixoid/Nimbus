&require: ["qstd"]


&styles: {

  choice: {
    Margins: {
      top:  10
    }
  }
}


&root: {

  &subs: [
  { &name: "Popup" &type: "qstd::popup"
        
    Visible: false
    Effects: [
      {&type: "qstd::noise"}
    ]
    Size: {w: 140, h: 82}
  }
  { &name: "PanelTop" &type: "qstd::layout_horz"

    Size: {w: 0, h: 50}
    Anchors: {
      top:  { active: true, control: "@^", side: "<-" }
      left: { active: true, control: "@^", side: "<-" }
      righ: { active: true, control: "@^", side: "->" }
    }

    Color: "Monet.BackDark"
    BorderRadius: 0

    &subs: [
    { &name: "MenuName" &type: "qstd::text"

      Anchors: {
        left: { active: true, control: "@PanelTop", side: "<-" }
        top:  { active: true, control: "@PanelTop", side: "<-" }
        bot:  { active: true, control: "@PanelTop", side: "->" }
      }

      Margins: {
        left: 14
      }

      Text: "QCL Application"
      FontSize: 20
    }
    ]
  }
  { &name: "PanelClient" &type: "qstd::layout_horz"

    Anchors: {
      top:  { active: true, control: "@PanelTop", side: "->" }
      bot:  { active: true, control: "@^", side: "->" }
      left: { active: true, control: "@^", side: "<-" }
      righ: { active: true, control: "@^", side: "->" }
    }

    Color: "Monet.BackDark"
    BorderRadius: 0

    &subs: [
    { &name: "Panel1" &type: "qstd::layout_vert" AutoSize: true

      Size: {w: 180}

      Anchors: {
        top:  { active: true }
      }

      Margins: {
        left: 10
        bot: 10
      }

      Paddings: {
        left: 10
        righ: 10
      }

      &subs: [
      { &name: "Edit1" &type: "qstd::edit" &style: "choice"
        Text: "Edit 1"
        Effects: [{&type: "qstd::noise"}]
      }
      { &name: "Radio1" &type: "qstd::radio" &style: "choice"
        Text: "Radio 1"
        Effects: [{&type: "qstd::noise"}]
      }
      { &name: "Radio2" &type: "qstd::radio" &style: "choice" Checked: true
        Text: "Radio 2"
        Effects: [{&type: "qstd::noise"}]
      }
      { &name: "Radio3" &type: "qstd::radio" &style: "choice"
        Text: "Radio 3"
        Effects: [{&type: "qstd::noise"}]
      }

      { &name: "Check1" &type: "qstd::check" &style: "choice"
        Text: "Check 1"
        Effects: [{&type: "qstd::noise"}]
      }
      { &name: "Check2" &type: "qstd::check" &style: "choice" Checked: true
        Text: "Check 2"
        Effects: [{&type: "qstd::noise"}]
      }
      { &name: "Check3" &type: "qstd::check" &style: "choice" Checked: true
        Text: "Check 3"
        Effects: [{&type: "qstd::noise"}]
      }

      { &name: "Toggle1" &type: "qstd::toggle" &style: "choice"
        Text: "Switch 1"
        Anchors: {
          left: {active: true, control: "@^", side: "<-"}
          righ: {active: true, control: "@^", side: "->"}
        }
        Effects: [{&type: "qstd::noise"}]
      }
      { &name: "Toggle2" &type: "qstd::toggle" &style: "choice" Checked: true
        Text: "Switch 2"
        Anchors: {
          left: {active: true, control: "@^", side: "<-"}
          righ: {active: true, control: "@^", side: "->"}
        }
        Effects: [{&type: "qstd::noise"}]
      }
      { &name: "Toggle3" &type: "qstd::toggle" &style: "choice"
        Text: "Switch 3"
        Anchors: {
          left: {active: true, control: "@^", side: "<-"}
          righ: {active: true, control: "@^", side: "->"}
        }
        Effects: [{&type: "qstd::noise"}]
      }

      { &name: "Text1" &type: "qstd::text" &style: "choice"  Text: "Text 1" }
      { &name: "Text2" &type: "qstd::chip" &style: "choice" AutoSize: true, Color: "Monet.Main"

        Paddings: {top: 8, bot: 8, left: 8, righ: 8}

        &subs: [ 
          { &name: "Text2" &type: "qstd::text" &style: "choice"  Text: "Text 2" }
        ]
      }
      { &name: "Text3" &type: "qstd::chip" &style: "choice" AutoSize: true, Color: "Monet.MainLight"

        &subs: [ 
          { &name: "Text3" &type: "qstd::text" &style: "choice"  Text: "Text 3" }
        ]
      }
      { &name: "Text4" &type: "qstd::card" &style: "choice" AutoSize: true, Color: "Monet.MainDark" Effects: [{&type: "qstd::noise"}]
      
        &subs: [ 
          { &name: "Text4" &type: "qstd::text" &style: "choice"  Text: "Text 4" }
        ]
      }
      { &name: "Text5" &type: "qstd::card" &style: "choice" AutoSize: true, Color: "Monet.MainLight" Effects: [{&type: "qstd::noise"}]
      
        &subs: [ 
          { &name: "Text5" &type: "qstd::text" &style: "choice"  Text: "Text 5" Color: "Monet.TextDark" }
        ]
      }
      ]
    }
    { &name: "Panel2" &type: "qstd::layout_vert" AutoSize: true

      Size: {w: 180, h: 0}

      Anchors: {
        top:  { active: true }
      }

      Margins: {
        left: 10
        bot: 10
      }

      Paddings: {
        left: 10
        righ: 10
      }

      &subs: [
      { &name: "Edit2" &type: "qstd::edit" &style: "choice"
        Text: "Edit 2"
        Effects: [{&type: "qstd::noise"}]
      }
      { &name: "ProgBar1" &type: "qstd::progbar" &style: "choice"
        Text: "Progbar1"
        Value: 20
        Anchors: {
          left: {active: true, control: "@^", side: "<-"}
          righ: {active: true, control: "@^", side: "->"}
        }
        Effects: [{&type: "qstd::noise"}]
      }

      { &name: "Slider1" &type: "qstd::slider" &style: "choice"
        Anchors: {
          left: {active: true, control: "@^", side: "<-"}
          righ: {active: true, control: "@^", side: "->"}
        }
        Effects: [{&type: "qstd::noise"}]
      }
      { &name: "Tabs1" &type: "qstd::tabs" &style: "choice"
        Tabs: ["Tab1", "Tab2", "Tab3"]
        TabID: 0
        Anchors: {
          left: {active: true, control: "@^", side: "<-"}
          righ: {active: true, control: "@^", side: "->"}
        }
        Effects: [{&type: "qstd::noise"}]
      }

      { &name: "Choice1" &type: "qstd::choice" &style: "choice"
        Threshold: 0
        Tabs: ["Choi1", "Choi2", "Choi3"]
        TabID: 1
        Anchors: {
          left: {active: true, control: "@^", side: "<-"}
          righ: {active: true, control: "@^", side: "->"}
        }
        Effects: [{&type: "qstd::noise"}]
      }

      { &name: "Choice2" &type: "qstd::choice" &style: "choice"
        Threshold: 4
        Tabs: ["Choi1", "Choi2", "Choi3"]
        TabID: 2
        Anchors: {
          left: {active: true, control: "@^", side: "<-"}
          righ: {active: true, control: "@^", side: "->"}
        }
        Effects: [{&type: "qstd::noise"}]
      }
    
      { &name: "PopupBtn" &type: "qstd::card" &style: "choice" AutoSize: true, Color: "Monet.MainDark" Effects: [{&type: "qstd::noise"}]

        &subs: [ 
          { &name: "PopupBtn" &type: "qstd::text" &style: "choice"  Text: "Popup" }
        ]

      }
      ]
    }
    { &name: "Panel3" &type: "qstd::layout_vert"

      Size: {w: 180}

      Anchors: {
        top:  { active: true }
        bot:  { active: true }
      }

      Margins: {
        left: 10
        bot: 10
      }

      Paddings: {
        left: 10
        righ: 10
      }

      &subs: [
      { &name: "__nil" &type: "qstd::text"

        Text: "Theme"
        FontSize: 18

        Margins: {
          left: 6
          top: 6
        }
      }
      { &name: "__nil" &type: "qstd::choice"
        
        ^OnChanged: "ThemeChange"
        
        Tabs: ["Dark", "Light"]
        TabID: 0
        Margins: {
          left: 6
          top: 6
        }
      }
      ]
    }
    ]
  }
  
  ]
}
